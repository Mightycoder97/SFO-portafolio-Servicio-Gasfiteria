---
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid grid grid-cols-4">
      
      <div class="footer-col brand-col">
        <a href="/" class="logo" aria-label="Ir a la página de inicio">
          <i class="ph ph-drop text-primary" aria-hidden="true"></i>
          <span class="logo-text">Gasfitero en Juliaca</span>
        </a>
        <p class="text-light mt-4">
          Expertos en fontanería y prevención. Estamos en Juliaca y cubrimos emergencias a nivel nacional.
        </p>
        <div class="social-links mt-4">
          <a href="#" aria-label="Visitar nuestra página de Facebook"><i class="ph ph-facebook-logo" aria-hidden="true"></i></a>
          <a href="#" aria-label="Visitar nuestro perfil de Instagram"><i class="ph ph-instagram-logo" aria-hidden="true"></i></a>
          <a href="#" aria-label="Contactar por WhatsApp"><i class="ph ph-whatsapp-logo" aria-hidden="true"></i></a>
        </div>
      </div>

      <div class="footer-col">
        <h3>Servicios</h3>
        <ul class="footer-links">
          <li><a href="/servicios#fugas">Detección de Fugas</a></li>
          <li><a href="/servicios#desatoro">Desatoro de Tuberías</a></li>
          <li><a href="/servicios#termas">Instalación de Termas</a></li>
          <li><a href="/servicios#cisternas">Limpieza de Cisternas</a></li>
          <li><a href="/servicios" class="text-primary font-medium">Ver todos &rarr;</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h3>Navegación</h3>
        <ul class="footer-links">
          <li><a href="/">Inicio</a></li>
          <li><a href="/servicios">Servicios</a></li>
          <li><a href="/cobertura">Cobertura Total</a></li>
          <li><a href="/contacto">Contacto</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h3>Contacto</h3>
        <ul class="footer-contact">
          <li>
            <i class="ph ph-map-pin"></i>
            <span>Juliaca, Puno, Perú. (Sede Central)</span>
          </li>
          <li>
            <i class="ph ph-phone"></i>
            <span>+51 987 654 321</span>
          </li>
          <li>
            <i class="ph ph-envelope-simple"></i>
            <span>emergencias@gasfiteroenjuliaca.pe</span>
          </li>
          <li>
            <i class="ph ph-clock"></i>
            <span>Atención 24/7 en Urgencias</span>
          </li>
        </ul>
      </div>
      
    </div>
    
    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} Gasfitero en Juliaca. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-bg-subtle);
    border-top: 1px solid var(--color-border);
    padding: 4rem 0 0 0;
    margin-top: 4rem;
  }

  .footer-col h3 {
    font-size: 1.25rem;
    margin-bottom: 1.5rem;
  }
  
  .mt-4 { margin-top: 1rem; }
  .font-medium { font-weight: 500; }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.25rem;
    font-weight: 800;
  }

  .logo i {
    font-size: 1.75rem;
  }

  .logo-text {
    color: var(--color-text-dark);
  }

  .social-links {
    display: flex;
    gap: 1rem;
  }

  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background-color: var(--color-border);
    border-radius: 50%;
    color: var(--color-text-dark);
    font-size: 1.25rem;
    transition: all 0.2s ease;
  }

  .social-links a:hover {
    background-color: var(--color-primary);
    color: white;
    transform: translateY(-2px);
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-links a {
    color: var(--color-text-light);
    transition: all 0.2s;
    display: inline-block;
    padding: 0.25rem 0; /* Expanded touch target for mobile */
  }

  .footer-links a:hover {
    color: var(--color-primary);
    padding-left: 0.25rem;
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-contact li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    color: var(--color-text-light);
  }

  .footer-contact i {
    font-size: 1.25rem;
    color: var(--color-secondary);
    margin-top: 0.125rem;
  }

  .footer-bottom {
    margin-top: 4rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--color-border);
    text-align: center;
    color: var(--color-text-light);
    font-size: 0.875rem;
  }
</style>
