---
const phoneNumber = "51994678713";
const displayPhone = "+51 994 678 713";
const whatsappMessage = "Hola! Vengo de la página web y necesito un servicio de gasfitería.";
---

<div class="floating-left">
  <!-- Botón WhatsApp -->
  <a 
    href={`https://wa.me/${phoneNumber}?text=${encodeURIComponent(whatsappMessage)}`} 
    target="_blank" 
    rel="noopener noreferrer" 
    class="float-btn float-wa" 
    aria-label="Contactar por WhatsApp"
  >
    <i class="ph ph-whatsapp-logo"></i>
  </a>
</div>

<div class="floating-right">
  <!-- Botón Teléfono -->
  <a 
    href={`tel:+${phoneNumber}`} 
    class="float-btn float-phone" 
    aria-label={`Llamar al ${displayPhone}`}
  >
    <i class="ph ph-phone"></i>
  </a>
</div>

<style>
  .floating-left {
    position: fixed;
    bottom: 30px;
    left: 30px;
    z-index: 1000;
  }

  .floating-right {
    position: fixed;
    bottom: 30px;
    right: 30px;
    z-index: 1000;
  }

  /* Base styles for both buttons */
  .float-btn {
    width: 65px;
    height: 65px;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    color: white;
    font-size: 34px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.4);
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    text-decoration: none;
    cursor: pointer;
    border: 3px solid rgba(255, 255, 255, 0.5); /* Glowing border effect */
  }

  .float-btn:hover, 
  .float-btn:focus {
    transform: translateY(-8px) scale(1.1);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
    border-color: white;
    outline: none;
  }

  /* Specific styles */
  .float-phone {
    background-color: var(--color-primary); 
    background-image: linear-gradient(135deg, var(--color-primary), #1a365d);
    animation: bounce-phone 3s infinite ease-in-out;
  }

  .float-wa {
    background-color: #25D366;
    background-image: linear-gradient(135deg, #25D366, #128C7E);
    animation: pulse-wa 2s infinite;
  }

  @keyframes pulse-wa {
    0% {
      box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.8), 0 4px 15px rgba(0, 0, 0, 0.4);
    }
    70% {
      box-shadow: 0 0 0 20px rgba(37, 211, 102, 0), 0 4px 15px rgba(0, 0, 0, 0.4);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(37, 211, 102, 0), 0 4px 15px rgba(0, 0, 0, 0.4);
    }
  }

  @keyframes bounce-phone {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  /* Hover pauses animations */
  .float-btn:hover {
    animation-play-state: paused;
  }

  /* Mobile Optimization */
  @media (max-width: 768px) {
    .floating-left {
      left: 15px;
      bottom: 20px;
    }
    .floating-right {
      right: 15px;
      bottom: 20px;
    }

    .float-btn {
      width: 55px;
      height: 55px;
      font-size: 28px;
      border-width: 2px;
    }
    
    .float-btn:hover, 
    .float-btn:focus {
      transform: translateY(-2px);
    }
  }
</style>
