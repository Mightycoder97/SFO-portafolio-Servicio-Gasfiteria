---
import Layout from '../layouts/Layout.astro';
import CTA from '../components/CTA.astro';

const allServices = [
  {
    title: "Detección de Fugas en Juliaca",
    description: "Utilizamos tecnología avanzada como geófonos y cámaras de inspección para localizar fugas ocultas de agua y desagüe en Juliaca sin necesidad de romper paredes innecesariamente. Esto ahorra tiempo y dinero en reparaciones en tu hogar en Juliaca.",
    icon: "ph ph-magnifying-glass-plus",
    id: "fugas"
  },
  {
    title: "Desatoro de Tuberías en Juliaca",
    description: "Atendemos obstrucciones severas en inodoros, lavaderos, duchas y redes principales de desagüe de Juliaca utilizando máquinas de balín o hidrojet de alta presión para una limpieza profunda y duradera en Juliaca.",
    icon: "ph ph-pipe",
    id: "desatoro"
  },
  {
    title: "Instalación y Reparación de Termas en Juliaca",
    description: "Técnicos especialistas en termas eléctricas, a gas y sistemas solares en todo Juliaca. Realizamos desde la instalación inicial hasta el mantenimiento preventivo y reparación correctiva para asegurar siempre agua caliente en Juliaca.",
    icon: "ph ph-thermometer-hot",
    id: "termas"
  },
  {
    title: "Sistemas Hidroneumáticos y Bombas en Juliaca",
    description: "Diseño, instalación y reparación de bombas de agua en Juliaca para garantizar una presión constante en todos los pisos de su domicilio, edificio o local comercial en Juliaca.",
    icon: "ph ph-engine",
    id: "bombas"
  },
  {
    title: "Limpieza de Cisternas en Juliaca",
    description: "Servicio profesional de lavado y desinfección integral de tanques elevados y cisternas subterráneas en Juliaca, asegurando que el agua que consume su familia en Juliaca esté 100% limpia y libre de bacterias.",
    icon: "ph ph-drop",
    id: "cisternas"
  },
  {
    title: "Remodelación y Mantenimiento en Juliaca",
    description: "Servicio completo para remodelación de baños y cocinas en todo Juliaca. Cambio de griferías, inodoros, mezcladoras, llaves de paso y tuberías antiguas por materiales modernos y eficientes para tu vivienda en Juliaca.",
    icon: "ph ph-wrench",
    id: "remodelacion"
  },
  {
    title: "Gasfitería de Urgencia 24/7 en Juliaca",
    description: "Atención inmediata para aquellas emergencias de gasfiteria en Juliaca que no pueden esperar: tuberías rotas, inundaciones repentinas o fallas críticas. Llegamos rápido desde nuestra base central en Juliaca a cualquier punto de la ciudad que lo requiera.",
    icon: "ph ph-ambulance",
    id: "urgencia"
  }
];
---

<Layout 
  title="Nuestros Servicios" 
  description="Expertos en detección de fugas de agua, desatoro de tuberías con máquinas, reparación de termas y limpieza de cisternas en Juliaca y todo el Perú. 24/7."
>
  <div class="page-header">
    <div class="container text-center animate-fade-in">
      <h1>Nuestros Servicios de <span class="text-highlight text-primary">Gasfitería en Juliaca</span></h1>
      <p class="page-desc text-light max-w-2xl mx-auto">Experiencia, garantía y tecnología como los mejores gasfiteros en Juliaca al servicio de tu hogar o empresa. Resolvemos desde pequeñas reparaciones en Juliaca hasta grandes instalaciones.</p>
    </div>
  </div>

  <section class="section pt-0">
    <div class="container">
      <div class="services-list">
        {allServices.map((service, index) => (
          <div id={service.id} class={`service-detail-card ${index % 2 !== 0 ? 'reverse' : ''}`}>
            <div class="service-icon-large">
              <i class={service.icon}></i>
            </div>
            <div class="service-content">
              <h2>{service.title}</h2>
              <p class="text-light">{service.description}</p>
              <ul class="service-benefits">
                <li><i class="ph ph-check-circle text-secondary"></i> Atención rápida garantizada</li>
                <li><i class="ph ph-check-circle text-secondary"></i> Personal técnico calificado</li>
                <li><i class="ph ph-check-circle text-secondary"></i> Presupuesto transparente</li>
              </ul>
              <a href={`https://wa.me/51987654321?text=Hola,%20necesito%20ayuda%20con%20el%20servicio%20de%20${encodeURIComponent(service.title)}`} target="_blank" class="btn btn-outline mt-4">Solicitar Servicio</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</Layout>

<style>
  .page-header {
    padding: 6rem 0 4rem;
    background-color: var(--color-bg-subtle);
    border-bottom: 1px solid var(--color-border);
  }

  h1 { font-size: clamp(2.5rem, 5vw, 3.5rem); }

  .page-desc {
    font-size: 1.125rem;
    margin-top: 1rem;
  }
  
  .max-w-2xl { max-width: 42rem; }
  .mx-auto { margin-left: auto; margin-right: auto; }
  .pt-0 { padding-top: 0; }
  .mt-4 { margin-top: 1.5rem; }

  .services-list {
    display: flex;
    flex-direction: column;
    gap: 4rem;
    margin-top: 4rem;
  }

  .service-detail-card {
    display: flex;
    align-items: center;
    gap: 4rem;
    background-color: white;
    padding: 3rem;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--color-border);
    transition: transform 0.3s, box-shadow 0.3s;
    scroll-margin-top: 100px;
  }

  .service-detail-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
  }

  .service-detail-card.reverse {
    flex-direction: row-reverse;
  }

  .service-icon-large {
    flex-shrink: 0;
    width: 15rem;
    height: 15rem;
    background-color: rgba(63, 87, 181, 0.05);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 6rem;
    color: var(--color-secondary);
    border: 2px dashed rgba(63, 87, 181, 0.2);
  }

  .service-content {
    flex: 1;
  }

  .service-content h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .service-content p {
    font-size: 1.125rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .service-benefits {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .service-benefits li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 500;
  }

  @media (max-width: 991px) {
    .service-detail-card, .service-detail-card.reverse {
      flex-direction: column;
      gap: 2rem;
      padding: 2rem;
      text-align: center;
    }
    
    .service-icon-large {
      width: 100%;
      height: 12rem;
    }

    .service-benefits li {
      justify-content: center;
    }
  }
</style>
